---
import { getCollection } from 'astro:content';
const frases = await getCollection("frases");
const slugs = frases.map(f => f.id);
const slugsJson = JSON.stringify(slugs);
---
<!DOCTYPE html>
<html lang="es-mx">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="frases-slugs" content={slugsJson} />
  <title>Frase del día · CIOG</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      background: #ffffff;
      font-family: 'Inter', sans-serif;
      transition: background 0.3s;
    }
    html.dark body { background: #000E14; }
    .loader {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
      opacity: 0;
      animation: fadeIn 0.2s ease 0.05s forwards;
    }
    @keyframes fadeIn { to { opacity: 1; } }
    .dots {
      display: flex;
      gap: 8px;
    }
    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #B2A4FF;
      animation: bounce 1.2s infinite ease-in-out;
    }
    .dot:nth-child(2) { animation-delay: 0.2s; background: #9f34ff; }
    .dot:nth-child(3) { animation-delay: 0.4s; background: #FFB4B4; }
    @keyframes bounce {
      0%, 80%, 100% { transform: scale(0.7); opacity: 0.5; }
      40% { transform: scale(1); opacity: 1; }
    }
    .label {
      font-size: 13px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #003049;
      opacity: 0.5;
    }
    html.dark .label { color: #ffffff; }
  </style>

  <script is:inline>
    /* ── Dark mode (antes del paint) ── */
    if (localStorage.darkMode === 'true' ||
        (!('darkMode' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }

    /* ── Redirect sin repetir las últimas 4 frases ── */
    const SLUGS = JSON.parse(document.querySelector('meta[name="frases-slugs"]').content);
    const HISTORY_KEY = 'frases_history';
    const MAX_HISTORY = 4;

    let hist = [];
    try { hist = JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]'); } catch(e) {}

    let candidates = SLUGS.filter(s => !hist.includes(s));
    if (candidates.length === 0) { candidates = SLUGS; hist = []; }

    const chosen = candidates[Math.floor(Math.random() * candidates.length)];

    hist.push(chosen);
    if (hist.length > MAX_HISTORY) hist.shift();
    try { localStorage.setItem(HISTORY_KEY, JSON.stringify(hist)); } catch(e) {}

    window.location.replace('/frases/' + chosen);
  </script>
</head>
<body>
  <div class="loader">
    <div class="dots">
      <div class="dot"></div>
      <div class="dot"></div>
      <div class="dot"></div>
    </div>
    <span class="label">Cargando frase…</span>
  </div>
</body>
</html>
