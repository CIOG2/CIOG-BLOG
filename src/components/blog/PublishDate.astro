---
const {date} = Astro.props;
const formatted = new Intl.DateTimeFormat('es-MX', { day: '2-digit', month: '2-digit', year: 'numeric' }).format(new Date(date));
---
<small class="
        text-pacamara-primary/50 font-pacamara-space tracking-widest transition-all duration-300 text-[16px]
        dark:text-white/40
    ">
    { formatted }
</small>
